      "type": "tool_result",
      "agent": "main",
      "content": "[0] file.read: File: src/main.ts (167 lines) [hash:0d1170f7]\n1|/**\r\n2| * This template is a production ready boilerplate for developing with `PlaywrightCrawler`.\r\n3| * Use this to bootstrap your projects using the most up-to-date code.\r\n4| * If you're looking for examples or want to learn more, see README.\r\n5| */\r\n6|\r\n7|// For more information, see https://crawlee.dev\r\n8|import { PlaywrightCrawler } from '@crawlee/playwright';\r\n9|// For more information, see https://docs.apify.com/sdk/js\r\n10|import { Actor, log } from 'apify';\r\n11|import { launchOptions as camoufoxLaunchOptions } from 'camoufox-js';\r\n12|import { firefox } from 'playwright';\r\n13|\r\n14|// this is ESM project, and as such, it requires you to specify extensions in your relative imports\r\n15|// read more about this here: https://nodejs.org/docs/latest-v18.x/api/esm.html#mandatory-file-extensions\r\n16|// note that we need to use `.js` even when inside TS files\r\n17|import { router } from './routes.js';\r\n18|\r\n19|// Common desktop viewport sizes for fingerprint randomization\r\n20|const COMMON_VIEWPORTS: [number, number][] = [\r\n21|    [1920, 1080],\r\n22|    [1366, 768],\r\n23|    [1440, 900],\r\n24|    [1536, 864],\r\n25|    [1280, 720],\r\n26|];\r\n27|\r\n28|function getRandomViewport(): [number, number] {\r\n29|    return COMMON_VIEWPORTS[Math.floor(Math.random() * COMMON_VIEWPORTS.length)];\r\n30|}\r\n31|\r\n32|// Tracker and analytics domains to block\r\n33|const BLOCKED_PATTERNS = [\r\n34|    /doubleclick\\.net/,\r\n35|    /google-analytics\\.com/,\r\n36|    /googletagmanager\\.com/,\r\n37|    /facebook\\.net/,\r\n38|    /amazon-adsystem\\.com/,\r\n39|    /scorecardresearch\\.com/,\r\n40|    /hotjar\\.com/,\r\n41|    /mouseflow\\.com/,\r\n42|    /newrelic\\.com/,\r\n43|];\r\n44|\r\n45|\r\n46|interface Input {\r\n47|    startUrls: {\r\n48|        url: string;\r\n49|        method?: 'GET' | 'HEAD' | 'POST' | 'PUT' | 'DELETE' | 'TRACE' | 'OPTIONS' | 'CONNECT' | 'PATCH';\r\n50|        headers?: Record<string, string>;\r\n51|        userData: Record<string, unknown>;\r\n52|    }[];\r\n53|    maxRequestsPerCrawl: number;\r\n54|}\r\n55|\r\n56|// Initialize the Apify SDK\r\n57|await Actor.init();\r\n58|\r\n59|// Structure of input is defined in input_schema.json\r\n60|const { startUrls = ['https://apify.com'], maxRequestsPerCrawl = 100 } =\r\n61|    (await Actor.getInput<Input>()) ?? ({} as Input);\r\n62|\r\n63|// `checkAccess` flag ensures the proxy credentials are valid, but the check can take a few hundred milliseconds.\r\n64|// Disable it for short runs if you are sure your proxy configuration is correct\r\n65|const proxyConfiguration = await Actor.createProxyConfiguration({\r\n66|    groups: ['RESIDENTIAL'],\r\n67|    countryCode: 'IT',\r\n68|    checkAccess: true\r\n69|});\r\n70|\r\n71|// Randomize viewport and use virtual headless mode for enhanced stealth\r\n72|const viewport = getRandomViewport();\r\n73|const useVirtualDisplay = process.env.HEADLESS_VIRTUAL !== 'false';\r\n74|console.log(`Using viewport ${viewport[0]}×${viewport[1]} and headless mode: ${useVirtualDisplay ? 'virtual' : 'standard'}`);\r\n75|\r\n76|const crawler = new PlaywrightCrawler({\r\n77|    maxRequestsPerCrawl,\r\n78|    useSessionPool: true,\r\n79|    sessionPoolOptions: { maxPoolSize: 5 },\r\n80|    maxConcurrency: 1,\r\n81|    maxRequestRetries: 3,\r\n82|    requestHandler: router,\r\n83|    preNavigationHooks: [\r\n84|        // Human-like behavior: random delay before navigation\r\n85|        async ({ page }, _context) => {\r\n86|            try {\r\n87|                // Random delay 1-4 seconds to simulate human hesitation\r\n88|                await page.waitForTimeout(1000 + Math.random() * 3000);\r\n89|            } catch (err) {\r\n90|                log.warning('Pre-navigation delay interrupted', { error: String(err) });\r\n91|            }\r\n92|\r\n93|            // Simulate cookie consent acceptance\r\n94|            try {\r\n95|                await page.evaluate(() => {\r\n96|                    document.cookie = 'cookie_consent=true; path=/; max-age=3600';\r\n97|                });\r\n98|            } catch (err) {\r\n99|                log.warning('Cookie consent simulation failed', { error: String(err) });\r\n100|            }\r\n101|        },\r\n102|        // Block trackers and analytics domains\r\n103|        async ({ page }) => {\r\n104|            await page.route('**/*', async (route) => {\r\n105|                const url = route.request().url();\r\n106|                const shouldBlock = BLOCKED_PATTERNS.some((pattern) => pattern.test(url));\r\n107|                if (shouldBlock) {\r\n108|                    await route.abort('blockedbyclient');\r\n109|                } else {\r\n110|                    await route.continue();\r\n111|                }\r\n112|            });\r\n113|        },\r\n114|    ],\r\n115|    postNavigationHooks: [\r\n116|        // Human-like behavior: simulate reading after page load\r\n117|        async ({ page }) => {\r\n118|            try {\r\n119|                // Progressive scroll: 10 steps with 300ms intervals\r\n120|                await page.evaluate(async () => {\r\n121|                    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\r\n122|                    const totalHeight = document.body.scrollHeight;\r\n123|                    const step = totalHeight / 10;\r\n124|                    for (let i = 1; i <= 10; i++) {\r\n125|                        window.scrollTo(0, i * step);\r\n126|                        await delay(300);\r\n127|                    }\r\n128|                });\r\n129|\r\n130|                // Mouse emulation: move mouse to random positions\r\n131|                const viewport = page.viewportSize() || { width: 1280, height: 720 };\r\n132|                for (let i = 0; i < 3; \n... [truncated 1611 chars] ...\n|        globs: ['https://apify.com/*'],\r\n9|        label: 'detail',\r\n10|    });\r\n11|});\r\n12|\r\n13|router.addHandler('detail', async ({ request, page, log, pushData }) => {\r\n14|    const title = await page.title();\r\n15|    log.info(`${title}`, { url: request.loadedUrl });\r\n16|\r\n17|    await pushData({\r\n18|        url: request.loadedUrl,\r\n19|        title,\r\n20|    });\r\n21|});\r\n22|\n\n---\n\n[2] file.read: File: package.json (43 lines) [hash:835af8e5]\n1|{\r\n2|    \"name\": \"crawlee-playwright-typescript-camoufox\",\r\n3|    \"version\": \"0.0.1\",\r\n4|    \"type\": \"module\",\r\n5|    \"description\": \"This is an example of an Apify Actor.\",\r\n6|    \"engines\": {\r\n7|        \"node\": \">=20.0.0\"\r\n8|    },\r\n9|    \"dependencies\": {\r\n10|        \"apify\": \"^3.7.0\",\r\n11|        \"camoufox-js\": \"^0.9.0\",\r\n12|        \"@crawlee/playwright\": \"^3.15.3\",\r\n13|        \"playwright\": \"1.60.0\"\r\n14|    },\r\n15|    \"devDependencies\": {\r\n16|        \"@apify/eslint-config\": \"^2.0.0\",\r\n17|        \"@apify/tsconfig\": \"^0.1.1\",\r\n18|        \"@types/node\": \"^24.0.0\",\r\n19|        \"eslint\": \"^9.29.0\",\r\n20|        \"eslint-config-prettier\": \"^10.1.5\",\r\n21|        \"globals\": \"^17.0.0\",\r\n22|        \"prettier\": \"^3.5.3\",\r\n23|        \"tsx\": \"^4.20.3\",\r\n24|        \"typescript\": \"^6.0.0\",\r\n25|        \"typescript-eslint\": \"^8.58.0\",\r\n26|        \"vitest\": \"^4.1.0\"\r\n27|    },\r\n28|    \"scripts\": {\r\n29|        \"start\": \"npm run start:dev\",\r\n30|        \"start:prod\": \"node dist/main.js\",\r\n31|        \"start:dev\": \"tsx src/main.ts\",\r\n32|        \"build\": \"tsc\",\r\n33|        \"lint\": \"eslint\",\r\n34|        \"lint:fix\": \"eslint --fix\",\r\n35|        \"format\": \"prettier --write .\",\r\n36|        \"format:check\": \"prettier --check .\",\r\n37|        \"test\": \"vitest run\",\r\n38|        \"postinstall\": \"npx camoufox-js fetch\"\r\n39|    },\r\n40|    \"author\": \"It's not you it's me\",\r\n41|    \"license\": 