                await page.evaluate(() => {\r\n96|                    document.cookie = 'cookie_consent=true; path=/; max-age=3600';\r\n97|                });\r\n98|            } catch (err) {\r\n99|                log.warning('Cookie consent simulation failed', { error: String(err) });\r\n100|            }\r\n101|        },\r\n102|        // Block trackers and analytics domains\r\n103|        async ({ page }) => {\r\n104|            await page.route('**/*', async (route) => {\r\n105|                const url = route.request().url();\r\n106|                const shouldBlock = BLOCKED_PATTERNS.some((pattern) => pattern.test(url));\r\n107|                if (shouldBlock) {\r\n108|                    await route.abort('blockedbyclient');\r\n109|                } else {\r\n110|                    await route.continue();\r\n111|                }\r\n112|            });\r\n113|        },\r\n114|    ],\r\n115|    postNavigationHooks: [\r\n116|        // Human-like behavior: simulate reading after page load\r\n117|        async ({ page }) => {\r\n118|            try {\r\n119|                // Progressive scroll: 10 steps with 300ms intervals\r\n120|                await page.evaluate(async () => {\r\n121|                    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\r\n122|                    const totalHeight = document.body.scrollHeight;\r\n123|                    const step = totalHeight / 10;\r\n124|                    for (let i = 1; i <= 10; i++) {\r\n125|                        window.scrollTo(0, i * step);\r\n126|                        await delay(300);\r\n127|                    }\r\n128|                });\r\n129|\r\n130|                // Mouse emulation: move mouse to random positions\r\n131|                const viewport = page.viewportSize() || { width: 1280, height: 720 };\r\n132|                for (let i = 0; i < 3; i++) {\r\n133|                    await page.mouse.move(\r\n134|                        Math.random() * viewport.width,\r\n135|                        Math.random() * viewport.height\r\n136|                    );\r\n137|                    await page.waitForTimeout(500);\r\n138|                }\r\n139|\r\n140|                // Reading wait: simulate reading time (2-5 seconds)\r\n141|                await page.waitForTimeout(2000 + Math.random() * 3000);\r\n142|            } catch (err) {\r\n143|                log.warning('Post-navigation hooks interrupted', { error: String(err) });\r\n144|            }\r\n145|        },\r\n146|    ],\r\n147|\r\n148|    launchContext: {\r\n149|        launcher: firefox,\r\n150|        launchOptions: await camoufoxLaunchOptions({\r\n151|            headless: true,\r\n152|            window: viewport,\r\n153|            proxy: await proxyConfiguration?.newUrl(),\r\n154|            geoip: true,\r\n155|            locale: \"it-IT\",\r\n156|            env: { TZ: 'Europe/Rome' },\r\n157|            humanize: true, // enable realistic mouse movement to reduce bot detection\r\n158|            // fonts: ['Times New Roman'] // <- custom Camoufox options\r\n159|        }),\r\n160|    },\r\n161|});\r\n162|\r\n163|await crawler.run(startUrls);\r\n164|\r\n165|// Exit successfully\r\n166|await Actor.exit();\r\n167|",
