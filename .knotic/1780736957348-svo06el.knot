  && rm -r ~/.npm\r\n49|\r\n50|# Copy built JS files from builder image\r\n51|COPY --from=builder --chown=myuser:myuser /home/myuser/dist ./dist\r\n52|\r\n53|# Next, copy the remaining files and directories with the source code.\r\n54|# Since we do this after NPM install, quick build will be really fast\r\n55|# for most source file changes.\r\n56|COPY --chown=myuser:myuser . ./\r\n57|\r\n58|# Run the image.\r\n59|CMD [\"node\", \"dist/main.js\"]\r\n60|\n\n---\n\n[1] file.read: File: .actor/actor.json (19 lines) [hash:2f0704e1]\n1|{\r\n2|    \"$schema\": \"https://apify.com/schemas/v1/actor.ide.json\",\r\n3|    \"actorSpecification\": 1,\r\n4|    \"name\": \"my-actor\",\r\n5|    \"title\": \"Camoufox Playwright Crawler TypeScript\",\r\n6|    \"description\": \"Crawlee and Playwright project with Camoufox in TypeScript.\",\r\n7|    \"version\": \"0.0\",\r\n8|    \"meta\": {\r\n9|        \"templateId\": \"ts-crawlee-playwright-camoufox\",\r\n10|        \"generatedBy\": \"<FILL-IN-MODEL>\"\r\n11|    },\r\n12|    \"input\": \"./input_schema.json\",\r\n13|    \"output\": \"./output_schema.json\",\r\n14|    \"storages\": {\r\n15|        \"dataset\": \"./dataset_schema.json\"\r\n16|    },\r\n17|    \"dockerfile\": \"../Dockerfile\"\r\n18|}\r\n19|\n\n---\n\n[2] run_in_terminal: ERROR - only read ops allowed in batch",
