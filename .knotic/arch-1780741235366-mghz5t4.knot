H';\r\n50|        headers?: Record<string, string>;\r\n51|        userData: Record<string, unknown>;\r\n52|    }[];\r\n53|    maxRequestsPerCrawl: number;\r\n54|}\r\n55|\r\n56|// Initialize the Apify SDK\r\n57|await Actor.init();\r\n58|\r\n59|// Structure of input is defined in input_schema.json\r\n60|const { startUrls = ['https://apify.com'], maxRequestsPerCrawl = 100 } =\r\n61|    (await Actor.getInput<Input>()) ?? ({} as Input);\r\n62|\r\n63|// `checkAccess` flag ensures the proxy credentials are valid, but the check can take a few hundred milliseconds.\r\n64|// Disable it for short runs if you are sure your proxy configuration is correct\r\n65|const proxyConfiguration = await Actor.createProxyConfiguration({\r\n66|    groups: ['RESIDENTIAL'],\r\n67|    countryCode: 'IT',\r\n68|    checkAccess: true\r\n69|});\r\n70|\r\n71|// Randomize viewport and use virtual headless mode for enhanced stealth\r\n72|const viewport = getRandomViewport();\r\n73|const useVirtualDisplay = process.env.HEADLESS_VIRTUAL !== 'false';\r\n74|console.log(`Using viewport ${viewport[0]}×${viewport[1]} and headless mode: ${useVirtualDisplay ? 'virtual' : 'standard'}`);\r\n75|\r\n76|const crawler = new PlaywrightCrawler({\r\n77|    maxRequestsPerCrawl,\r\n78|    useSessionPool: true,\r\n79|    sessionPoolOptions: { maxPoolSize: 5 },\r\n80|    requestHandler: router,\r\n81|    preNavigationHooks: [\r\n82|        // Human-like behavior: random delay before navigation\r\n83|        async ({ page }, _context) => {\r\n84|            try {\r\n85|                // Random delay 1-4 seconds to simulate human hesitation\r\n86|                await page.waitForTimeout(1000 + Math.random() * 3000);\r\n87|            } catch (err) {\r\n88|                log.warning('Pre-navigation delay interrupted', { error: String(err) });\r\n89|            }\r\n90|\r\n91|            // Simulate cookie consent acceptance\r\n92|            try {\r\n93|                await page.evaluate(() => {\r\n94|                    document.cookie = 'cookie_consent=true; path=/; max-age=3600';\r\n95|                });\r\n96|            } catch (err) {\r\n97|                log.warning('Cookie consent simulation failed', { error: String(err) });\r\n98|            }\r\n99|        },\r\n100|        // Block trackers and analytics domains\r\n101|        async ({ page }) => {\r\n102|            await page.route('**/*', async (route) => {\r\n103|                const url = route.request().url();\r\n104|                const shouldBlock = BLOCKED_PATTERNS.some((pattern) => pattern.test(url));\r\n105|                if (shouldBlock) {\r\n106|                    await route.abort('blockedbyclient');\r\n107|                } else {\r\n108|                    await route.continue();\r\n109|                }\r\n110|            });\r\n111|        },\r\n112|    ],\r\n113|    postNavigationHooks: [\r\n114|        // Human-like behavior: simulate reading after page load\r\n115|        async ({ page }) => {\r\n116|            try {\r\n117|                // Progressive scroll: 10 steps with 300ms intervals\r\n118|                await page.evaluate(async () => {\r\n119|                    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\r\n120|                    const totalHeight = document.body.scrollHeight;\r\n121|                    const step = totalHeight / 10;\r\n122|                    for (let i = 1; i <= 10; i++) {\r\n123|                        window.scrollTo(0, i * step);\r\n124|                        await delay(300);\r\n125|                    }\r\n126|                });\r\n127|\r\n128|                // Mouse emulation: move mouse to random positions\r\n129|                const viewport = page.viewportSize() || { width: 1280, height: 720 };\r\n130|                for (let i = 0; i < 3; i++) {\r\n131|                    await page.mouse.move(\r\n132|                        Math.random() * viewport.width,\r\n133|                        Math.random() * viewport.height\r\n13