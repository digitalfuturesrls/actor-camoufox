      "content": "File: Dockerfile (60 lines) [hash:3366c9f9]\n1|# Specify the base Docker image. You can read more about\n2|# the available images at https://crawlee.dev/docs/guides/docker-images\n3|# You can also use any other image from Docker Hub.\n4|FROM apify/actor-node-playwright-camoufox:24-1.60.0 AS builder\n5|\n6|# Check preinstalled packages\n7|RUN npm ls @crawlee/core apify puppeteer playwright\n8|\n9|# Copy just package.json and package-lock.json\n10|# to speed up the build using Docker layer cache.\n11|COPY --chown=myuser:myuser package*.json Dockerfile ./\n12|\n13|# Check Playwright version is the same as the one from base image.\n14|RUN node check-playwright-version.mjs\n15|\n16|# Install all dependencies. Don't audit to speed up the installation.\n17|RUN npm install --include=dev --audit=false\n18|\n19|# Next, copy the source files using the user set\n20|# in the base image.\n21|COPY --chown=myuser:myuser . ./\n22|\n23|# Install all dependencies and build the project.\n24|# Don't audit to speed up the installation.\n25|RUN npm run build\n26|\n27|# Create final image\n28|FROM apify/actor-node-playwright-camoufox:24-1.60.0\n29|\n30|# Check preinstalled packages\n31|RUN npm ls @crawlee/core apify puppeteer playwright\n32|\n33|# Copy just package.json and package-lock.json\n34|# to speed up the build using Docker layer cache.\n35|COPY --chown=myuser:myuser package*.json ./\n36|\n37|# Install NPM packages, skip development dependencies to\n38|# keep the image small. Avoid logging too much and print the dependency\n39|# tree for debugging\n40|RUN npm --quiet set progress=false \\\n41|    && npm install --omit=dev \\\n42|    && echo \"Installed NPM packages:\" \\\n43|    && (npm list --omit=dev --all || true) \\\n44|    && echo \"Node.js version:\" \\\n45|    && node --version \\\n46|    && echo \"NPM version:\" \\\n47|    && npm --version \\\n48|    && rm -r ~/.npm\n49|\n50|# Copy built JS files from builder image\n51|COPY --from=builder --chown=myuser:myuser /home/myuser/dist ./dist\n52|\n53|# Next, copy the remaining files and directories with the source code.\n54|# Since we do this after NPM install, quick build will be really fast\n55|# for most source file changes.\n56|COPY --chown=myuser:myuser . ./\n57|\n58|# Run the image.\n59|CMD [\"node\", \"dist/main.js\"]\n60|",
