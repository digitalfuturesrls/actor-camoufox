      "type": "tool_result",
      "agent": "main",
      "content": "File: src/warmup.ts (103 lines) [hash:267816f6]\n1|/**\n2| * Warmup module: launches a standalone Camoufox browser to \"warm\" the fingerprint\n3| * before the actual crawl begins. Visits Google and performs human-like interactions\n4| * to stabilize the browser fingerprint and establish the proxy session.\n5| */\n6|\n7|import type { LaunchOptions } from 'playwright';\n8|\n9|import { firefox } from 'playwright';\n10|import { log } from 'apify';\n11|\n12|/**\n13| * Warmups the Camoufox browser fingerprint by visiting Google and performing\n14| * human-like interactions before the actual crawl starts.\n15| *\n16| * @param launchOptions - Pre-computed Camoufox launch options from main.ts\n17| * @param proxyUrl - Optional proxy URL to override the one in launchOptions\n18| */\n19|export async function warmupBrowser(\n20|    launchOptions: LaunchOptions,\n21|    proxyUrl?: string,\n22|): Promise<void> {\n23|    log.info('[Warmup] Starting mandatory warmup phase');\n24|\n25|    let browser;\n26|    try {\n27|        // Merge proxy URL if provided separately\n28|        const warmupOptions: LaunchOptions = { ...launchOptions };\n29|        if (proxyUrl) {\n30|            warmupOptions.proxy = proxyUrl as any;\n31|        }\n32|\n33|        log.info('[Warmup] Launching browser for warmup...');\n34|        browser = await firefox.launch(warmupOptions);\n35|\n36|        const context = await browser.newContext({\n37|            viewport: { width: 1280, height: 720 },\n38|        });\n39|        const page = await context.newPage();\n40|\n41|        try {\n42|            log.info('[Warmup] Navigating to https://www.google.com');\n43|\n44|            await page.goto('https://www.google.com', {\n45|                waitUntil: 'networkidle',\n46|                timeout: 15000,\n47|            });\n48|\n49|            // Dismiss cookie consent if present (try Italian first, then English)\n50|            for (const buttonText of ['Accetta tutto', 'Accept all']) {\n51|                try {\n52|                    const cookieButton = page.locator(`button:has-text(\"${buttonText}\")`);\n53|                    if (await cookieButton.isVisible({ timeout: 2000 })) {\n54|                        await cookieButton.click();\n55|                        log.debug(`[Warmup] Dismissed cookie banner: \"${buttonText}\"`);\n56|                        break;\n57|                    }\n58|                } catch {\n59|                    // Button not found or not visible, try next\n60|                }\n61|            }\n62|\n63|            // Wait for search box\n64|            const searchBox = page.locator('input[name=\"q\"]');\n65|            await searchBox.waitFor({ timeout: 5000 });\n66|\n67|            // Click search box and type with human-like delay\n68|            await searchBox.click();\n69|            await page.mouse.move(640, 360);\n70|            await page.waitForTimeout(200);\n71|\n72|            await page.keyboard.type('Apify web scraping', { delay: 100 });\n73|\n74|            // Submit search\n75|            await page.keyboard.press('Enter');\n76|            log.info('[Warmup] Search submitted, waiting for results...');\n77|\n78|            // Wait for search results to appear\n79|            await page.waitForSelector('#search', { timeout: 5000 }).catch(() => {\n80|                log.debug('[Warmup] Search results selector not found (partial warmup)');\n81|            });\n82|\n83|            // Final human-like pause\n84|            await page.waitForTimeout(2000);\n85|\n86|            log.info('[Warmup] Warmup complete, closing page...');\n87|            await page.close();\n88|        } catch (err) {\n89|            log.warning(`[Warmup] Page interaction error: ${String(err)}`);\n90|            try {\n91|                await page?.close();\n92|            } catch {\n93|                // Ignore close errors\n94|            }\n95|        } finally {\n96|            await browser?.close();\n97|        }\n98|\n99|        log.debug('[Warmup] Browser closed, warmup finished');\n100|    } catch (err) {\n101|        log.warning(`[Warmup] Browser launch failed but continuing: ${String(err)}`);\n102|    }\n103|}",
