      "content": "File: src/main.ts (195 lines) [hash:a8cf58bf]\n1|/**\r\n2| * This template is a production ready boilerplate for developing with `PlaywrightCrawler`.\r\n3| * Use this to bootstrap your projects using the most up-to-date code.\r\n4| * If you're looking for examples or want to learn more, see README.\r\n5| */\r\n6|\r\n7|// For more information, see https://crawlee.dev\r\n8|import { PlaywrightCrawler } from '@crawlee/playwright';\r\n9|// For more information, see https://docs.apify.com/sdk/js\r\n10|import { Actor, log } from 'apify';\r\n11|import { launchOptions as camoufoxLaunchOptions } from 'camoufox-js';\r\n12|import { firefox } from 'playwright';\r\n13|\r\n14|// this is ESM project, and as such, it requires you to specify extensions in your relative imports\r\n15|// read more about this here: https://nodejs.org/docs/latest-v18.x/api/esm.html#mandatory-file-extensions\r\n16|// note that we need to use `.js` even when inside TS files\r\n17|import { router } from './routes.js';\r\n18|\r\n19|// Common desktop viewport sizes for fingerprint randomization\r\n20|const COMMON_VIEWPORTS: [number, number][] = [\r\n21|    [1920, 1080],\r\n22|    [1366, 768],\r\n23|    [1440, 900],\r\n24|    [1536, 864],\r\n25|    [1280, 720],\r\n26|];\r\n27|\r\n28|function getRandomViewport(): [number, number] {\r\n29|    return COMMON_VIEWPORTS[Math.floor(Math.random() * COMMON_VIEWPORTS.length)];\r\n30|}\r\n31|\r\n32|// Tracker and analytics domains to block\r\n33|const BLOCKED_PATTERNS = [\r\n34|    /doubleclick\\.net/,\r\n35|    /google-analytics\\.com/,\r\n36|    /googletagmanager\\.com/,\r\n37|    /facebook\\.net/,\r\n38|    /amazon-adsystem\\.com/,\r\n39|    /scorecardresearch\\.com/,\r\n40|    /hotjar\\.com/,\r\n41|    /mouseflow\\.com/,\r\n42|    /newrelic\\.com/,\r\n43|    /datadome\\.co/,\r\n44|    /adnxs\\.com/,\r\n45|    /accounts\\.google\\.com\\/gsi/,\r\n46|];\r\n47|\r\n48|\r\n49|interface Input {\r\n50|    startUrls: Array<{ url: string; tag?: string }>;\r\n51|    maxRequestsPerCrawl: number;\r\n52|}\r\n53|\r\n54|// Initialize the Apify SDK\r\n55|await Actor.init();\r\n56|\r\n57|// Structure of input is defined in input_schema.json\r\n58|const { startUrls = [{ url: 'https://apify.com' }], maxRequestsPerCrawl = 100 } =\r\n59|    (await Actor.getInput<Input>()) ?? ({} as Input);\r\n60|\r\n61|// `checkAccess` flag ensures the proxy credentials are valid, but the check can take a few hundred milliseconds.\r\n62|// Disable it for short runs if you are sure your proxy configuration is correct\r\n63|const proxyConfiguration = await Actor.createProxyConfiguration({\r\n64|    groups: ['RESIDENTIAL'],\r\n65|    countryCode: 'IT',\r\n66|    checkAccess: true\r\n67|});\r\n68|\r\n69|// Randomize viewport and use virtual headless mode for enhanced stealth\r\n70|const viewport = getRandomViewport();\r\n71|const useVirtualDisplay = process.env.HEADLESS_VIRTUAL !== 'false';\r\n72|console.log(`Using viewport ${viewport[0]}×${viewport[1]} and headless mode: ${useVirtualDisplay ? 'virtual' : 'standard'}`);\r\n73|\r\n74|const crawler = new PlaywrightCrawler({\r\n75|    maxRequestsPerCrawl,\r\n76|    useSessionPool: true,\r\n77|    sessionPoolOptions: { maxPoolSize: 5 },\r\n78|    maxConcurrency: 1,\r\n79|    maxRequestRetries: 3,\r\n80|    requestHandler: router,\r\n81|    preNavigationHooks: [\r\n82|        // Block tracker and anti-bot domains before navigation\r\n83|        async ({ page }, _context) => {\r\n84|            await page.route('**/*', (route) => {\r\n85|                const url = route.request().url();\r\n86|                const shouldBlock = BLOCKED_PATTERNS.some((p) => p.test(url));\r\n87|                if (shouldBlock) {\r\n88|                    return route.abort('blockedbyclient');\r\n89|                }\r\n90|                return route.continue();\r\n91|            });\r\n92|        },\r\n93|\r\n94|        // Human-like behavior: random delay before navigation\r\n95|        async ({ page }, _context) => {\r\n96|            try {\r\n97|                // Random delay 1-4 seconds to simulate human hesitation\r\n98|                await page.waitForTimeout(1000 + Math.random() * 3000);\r\n99|            } catch (err) {\r\n100|                log.warning('Pre-navigation delay interrupted', { error: String(err) });\r\n101|            }\r\n102|\r\n103|            // Simulate cookie consent acceptance\r\n104|            try {\r\n105|                await page.evaluate(() => {\r\n106|                    document.cookie = 'cookie_consent=true; path=/; max-age=3600';\r\n107|                });\r\n108|            } catch (err) {\r\n109|                log.warning('Cookie consent simulation failed', { error: String(err) });\r\n110|            }\r\n111|        },\r\n112|\r\n113|    ],\r\n114|    postNavigationHooks: [\r\n115|        // Human-like behavior: simulate reading after page load\r\n116|        async ({ page }) => {\r\n117|            try {\r\n118|                // Progressive scroll: 10 steps with 300ms intervals\r\n119|                await page.evaluate(async () => {\r\n120|                    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\r\n121|                    const totalHeight = document.body.scrollHeight;\r\n122|                    const step = totalHeight / 10;\r\n123|                    for (let i = 1; i <= 10; i++) {\r\n124|                        window.scrollTo(0, i * step);\r\n125|                        await delay(300);\r\n126|                    }\r\n127|                });\r\n128|\r\n129|                // Mouse emulation: move mouse to random positions\r\n130|                const viewport = page.viewportSize() || { width: 1280, height: 720 };\r\n131|                for (let i = 0; i < 3; i++) {\r\n132|                    await page.mouse.move(\r\n133|                        Math.random() * viewport.width,\r\n134|                        Math.random() * viewport.height\r\n135|                    );\r\n136|                    await page.waitForTimeout(500);\r\n137|                }\r\n138|\r\n139|                // Reading wait: simulate reading time (2-5 seconds)\r\n140|                await page.waitForTimeout(2000 + Math.random() * 3000);\r\n141|            } catch (err) {\r\n142|                log.warning('Post-navigation hooks interrupted', { error: String(err) });\r\n143|            }\r\n144|        },\r\n145|    ],\r\n146|    proxyConfiguration,\r\n147|    launchContext: {\r\n148|        launcher: firefox,\r\n149|        launchOptions: await camoufoxLaunchOptions({\r\n150|            headless: true,\r\n151|            //window: viewport,\r\n152|            proxy: await proxyConfiguration?.newUrl(),\r\n153|            geoip: true,\r\n154|            locale: \"it-IT\",\r\n155|            env: { TZ: 'Europe/Rome' },\r\n156|            humanize: true, // enable realistic mouse movement to reduce bot detection\r\n157|            // fonts: ['Times New Roman'] // <- custom Camoufox options\r\n158|        }),\r\n159|    },\r\n160|});\r\n161|\r\n162|// Map input to requests with labels from tags\r\n163|log.info('Mapping input to requests with labels...', { count: startUrls.length });\r\n164|\r\n165|const requests = startUrls.map((item, index, arr) => {\r\n166|    const label = item.tag && item.tag.trim() ? item.tag.trim() : undefined;\r\n167|\r\n168|    if (!item.url) {\r\n169|        log.warning('Missing url in startUrl entry', { item });\r\n170|    }\r\n171|\r\n172|    // Se ci sono almeno 2 URL e questo e il primo, passa il secondo URL nel userData\r\n173|    // cosi il handler puo fare goto alla pagina target dopo il warmup\r\n174|    const userData: Record<string, unknown> = {};\r\n175|    if (index === 0 && arr.length >= 2) {\r\n176|        userData.targetUrl = arr[1].url;\r\n177|    }\r\n178|\r\n179|    return {\r\n180|        url: item.url,\r\n181|        label,\r\n182|        userData,\r\n183|    };\r\n184|}).filter((_req, index) => {\r\n185|    // Se ci sono 2 URL, skippa il secondo perche ci navighiamo via goto dal primo\r\n186|    return !(startUrls.length >= 2 && index === 1);\r\n187|});\r\n188|\r\n189|log.info('Starting crawl with requests...', { requests });\r\n190|\r\n191|await crawler.run(requests);\r\n192|\r\n193|// Exit successfully\r\n194|await Actor.exit();\r\n195|",
