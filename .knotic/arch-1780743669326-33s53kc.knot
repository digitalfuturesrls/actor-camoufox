ONNECT' | 'PATCH';\r\n50|        headers?: Record<string, string>;\r\n51|        userData: Record<string, unknown>;\r\n52|    }[];\r\n53|    maxRequestsPerCrawl: number;\r\n54|}\r\n55|\r\n56|// Initialize the Apify SDK\r\n57|await Actor.init();\r\n58|\r\n59|// Structure of input is defined in input_schema.json\r\n60|const { startUrls = ['https://apify.com'], maxRequestsPerCrawl = 100 } =\r\n61|    (await Actor.getInput<Input>()) ?? ({} as Input);\r\n62|\r\n63|// `checkAccess` flag ensures the proxy credentials are valid, but the check can take a few hundred milliseconds.\r\n64|// Disable it for short runs if you are sure your proxy configuration is correct\r\n65|const proxyConfiguration = await Actor.createProxyConfiguration({\r\n66|    groups: ['RESIDENTIAL'],\r\n67|    countryCode: 'IT',\r\n68|    checkAccess: true\r\n69|});\r\n70|\r\n71|// Randomize viewport and use virtual headless mode for enhanced stealth\r\n72|const viewport = getRandomViewport();\r\n73|const useVirtualDisplay = process.env.HEADLESS_VIRTUAL !== 'false';\r\n74|console.log(`Using viewport ${viewport[0]}×${viewport[1]} and headless mode: ${useVirtualDisplay ? 'virtual' : 'standard'}`);\r\n75|\r\n76|const crawler = new PlaywrightCrawler({\r\n77|    maxRequestsPerCrawl,\r\n78|    useSessionPool: true,\r\n79|    sessionPoolOptions: { maxPoolSize: 5 },\r\n80|    maxConcurrency: 1,\r\n81|    maxRequestRetries: 3,\r\n82|    requestHandler: router,\r\n83|    preNavigationHooks: [\r\n84|        // Human-like behavior: random delay before navigation\r\n85|        async ({ page }, _context) => {\r\n86|            try {\r\n87|                // Random delay 1-4 seconds to simulate human hesitation\r\n88|                await page.waitForTimeout(1000 + Math.random() * 3000);\r\n89|            } catch (err) {\r\n90|                log.warning('Pre-navigation delay interrupted', { error: String(err) });\r\n91|            }\r\n92|\r\n93|            // Simulate cookie consent acceptance\r\n94|            try {\