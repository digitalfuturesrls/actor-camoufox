wport,\r\n148|            proxy: await proxyConfiguration?.newUrl(),\r\n149|            geoip: true,\r\n150|            locale: \"it-IT\",\r\n151|            env: { TZ: 'Europe/Rome' },\r\n152|            humanize: true, // enable realistic mouse movement to reduce bot detection\r\n153|            // fonts: ['Times New Roman'] // <- custom Camoufox options\r\n154|        }),\r\n155|    },\r\n156|});\r\n157|\r\n158|// Map input to requests with labels from tags\r\n159|log.info('Mapping input to requests with labels...', { count: startUrls.length });\r\n160|\r\n161|const requests = startUrls.map((item) => {\r\n162|    const label = item.tag && item.tag.trim() ? item.tag.trim() : undefined;\r\n163|\r\n164|    if (!item.url) {\r\n165|        log.warning('Missing url in startUrl entry', { item });\r\n166|    }\r\n167|\r\n168|    return {\r\n169|        url: item.url,\r\n170|        label,\r\n171|    };\r\n172|});\r\n173|\r\n174|await crawler.run(requests);\r\n175|\r\n176|// Exit successfully\r\n177|await Actor.exit();\r\n178|\n\n---\n\n[1] file.read: File: src/routes.ts (37 lines) [hash:6cf65755]\n1|import { createPlaywrightRouter } from '@crawlee/playwright';\r\n2|\r\n3|export const router = createPlaywrightRouter();\r\n4|\r\n5|router.addDefaultHandler(async ({ enqueueLinks, log }) => {\r\n6|    log.info(`enqueueing new URLs`);\r\n7|    await enqueueLinks({\r\n8|        globs: ['https://apify.com/*'],\r\n9|        label: 'detail',\r\n10|    });\r\n11|});\r\n12|\r\n13|router.addHandler('detail', async ({ request, page, log, pushData }) => {\r\n14|    const title = await page.title();\r\n15|    log.info(`${title}`, { url: request.loadedUrl });\r\n16|\r\n17|    await pushData({\r\n18|        url: request.loadedUrl,\r\n19|        title,\r\n20|    });\r\n21|});\r\n22|\r\n23|router.addHandler('list', async ({ request, page, log, pushData }) => {\r\n24|    log.info(`Extracting announcement links from ${request.loadedUrl}`);\r\n25|\r\n26|    const hrefs = await page.locator('xp