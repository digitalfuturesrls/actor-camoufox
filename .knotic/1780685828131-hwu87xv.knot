      "content": "File: src/main.ts (162 lines) [hash:a106ad24]\n1|/**\r\n2| * This template is a production ready boilerplate for developing with `PlaywrightCrawler`.\r\n3| * Use this to bootstrap your projects using the most up-to-date code.\r\n4| * If you're looking for examples or want to learn more, see README.\r\n5| */\r\n6|\r\n7|// For more information, see https://crawlee.dev\r\n8|import { PlaywrightCrawler } from '@crawlee/playwright';\r\n9|// For more information, see https://docs.apify.com/sdk/js\r\n10|import { Actor, log } from 'apify';\r\n11|import { launchOptions as camoufoxLaunchOptions } from 'camoufox-js';\r\n12|import { firefox } from 'playwright';\r\n13|\r\n14|// Common desktop viewport sizes for fingerprint randomization\r\n15|const COMMON_VIEWPORTS: [number, number][] = [\r\n16|    [1920, 1080],\r\n17|    [1366, 768],\r\n18|    [1440, 900],\r\n19|    [1536, 864],\r\n20|    [1280, 720],\r\n21|];\r\n22|\r\n23|function getRandomViewport(): [number, number] {\r\n24|    return COMMON_VIEWPORTS[Math.floor(Math.random() * COMMON_VIEWPORTS.length)];\r\n25|}\r\n26|\r\n27|// Tracker and analytics domains to block\r\n28|const BLOCKED_PATTERNS = [\r\n29|    /doubleclick\\.net/,\r\n30|    /google-analytics\\.com/,\r\n31|    /googletagmanager\\.com/,\r\n32|    /facebook\\.net/,\r\n33|    /amazon-adsystem\\.com/,\r\n34|    /scorecardresearch\\.com/,\r\n35|    /hotjar\\.com/,\r\n36|    /mouseflow\\.com/,\r\n37|    /newrelic\\.com/,\r\n38|];\r\n39|\r\n40|// this is ESM project, and as such, it requires you to specify extensions in your relative imports\r\n41|// read more about this here: https://nodejs.org/docs/latest-v18.x/api/esm.html#mandatory-file-extensions\r\n42|// note that we need to use `.js` even when inside TS files\r\n43|import { router } from './routes.js';\r\n44|\r\n45|interface Input {\r\n46|    startUrls: {\r\n47|        url: string;\r\n48|        method?: 'GET' | 'HEAD' | 'POST' | 'PUT' | 'DELETE' | 'TRACE' | 'OPTIONS' | 'CONNECT' | 'PATCH';\r\n49|        headers?: Record<string, string>;\r\n50|        userData: Record<string, unknown>;\r\n51|    }[];\r\n52|    maxRequestsPerCrawl: number;\r\n53|}\r\n54|\r\n55|// Initialize the Apify SDK\r\n56|await Actor.init();\r\n57|\r\n58|// Structure of input is defined in input_schema.json\r\n59|const { startUrls = ['https://apify.com'], maxRequestsPerCrawl = 100 } =\r\n60|    (await Actor.getInput<Input>()) ?? ({} as Input);\r\n61|\r\n62|// `checkAccess` flag ensures the proxy credentials are valid, but the check can take a few hundred milliseconds.\r\n63|// Disable it for short runs if you are sure your proxy configuration is correct\r\n64|const proxyConfiguration = await Actor.createProxyConfiguration({\r\n65|    groups: ['RESIDENTIAL'],\r\n66|    countryCode: 'IT',\r\n67|    checkAccess: true\r\n68|});\r\n69|\r\n70|// Randomize viewport and use virtual headless mode for enhanced stealth\r\n71|const viewport = getRandomViewport();\r\n72|const useVirtualDisplay = process.env.HEADLESS_VIRTUAL !== 'false';\r\n73|console.log(`Using viewport ${viewport[0]}×${viewport[1]} and headless mode: ${useVirtualDisplay ? 'virtual' : 'standard'}`);\r\n74|\r\n75|const crawler = new PlaywrightCrawler({\r\n76|    proxyConfiguration,\r\n77|    maxRequestsPerCrawl,\r\n78|    requestHandler: router,\r\n79|    preNavigationHooks: [\r\n80|        // Human-like behavior: random delay before navigation\r\n81|        async ({ page }, _context) => {\r\n82|            try {\r\n83|                // Random delay 1-4 seconds to simulate human hesitation\r\n84|                await page.waitForTimeout(1000 + Math.random() * 3000);\r\n85|            } catch (err) {\r\n86|                log.warning('Pre-navigation delay interrupted', { error: String(err) });\r\n87|            }\r\n88|\r\n89|            // Simulate cookie consent acceptance\r\n90|            try {\r\n91|                await page.evaluate(() => {\r\n92|                    document.cookie = 'cookie_consent=true; path=/; max-age=3600';\r\n93|                });\r\n94|            } catch (err) {\r\n95|                log.warning('Cookie consent simulation failed', { error: String(err) });\r\n96|            }\r\n97|        },\r\n98|        // Block trackers and analytics domains\r\n99|        async ({ page }) => {\r\n100|            await page.route('**/*', async (route) => {\r\n101|                const url = route.request().url();\r\n102|                const shouldBlock = BLOCKED_PATTERNS.some((pattern) => pattern.test(url));\r\n103|                if (shouldBlock) {\r\n104|                    await route.abort('blockedbyclient');\r\n105|                } else {\r\n106|                    await route.continue();\r\n107|                }\r\n108|            });\r\n109|        },\r\n110|    ],\r\n111|    postNavigationHooks: [\r\n112|        // Human-like behavior: simulate reading after page load\r\n113|        async ({ page }) => {\r\n114|            try {\r\n115|                // Progressive scroll: 10 steps with 300ms intervals\r\n116|                await page.evaluate(async () => {\r\n117|                    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\r\n118|                    const totalHeight = document.body.scrollHeight;\r\n119|                    const step = totalHeight / 10;\r\n120|                    for (let i = 1; i <= 10; i++) {\r\n121|                        window.scrollTo(0, i * step);\r\n122|                        await delay(300);\r\n123|                    }\r\n124|                });\r\n125|\r\n126|                // Mouse emulation: move mouse to random positions\r\n127|                const viewport = page.viewportSize() || { width: 1280, height: 720 };\r\n128|                for (let i = 0; i < 3; i++) {\r\n129|                    await page.mouse.move(\r\n130|                        Math.random() * viewport.width,\r\n131|                        Math.random() * viewport.height\r\n132|                    );\r\n133|                    await page.waitForTimeout(500);\r\n134|                }\r\n135|\r\n136|                // Reading wait: simulate reading time (2-5 seconds)\r\n137|                await page.waitForTimeout(2000 + Math.random() * 3000);\r\n138|            } catch (err) {\r\n139|                log.warning('Post-navigation hooks interrupted', { error: String(err) });\r\n140|            }\r\n141|        },\r\n142|    ],\r\n143|    launchContext: {\r\n144|        launcher: firefox,\r\n145|        launchOptions: await camoufoxLaunchOptions({\r\n146|            headless: true, // Camoufox handles virtual display internally when geoip is enabled\r\n147|            window: viewport,\r\n148|            proxy: await proxyConfiguration?.newUrl(),\r\n149|            geoip: true,\r\n150|            locale: \"it-IT\",\r\n151|            env: { TZ: 'Europe/Rome' },\r\n152|            humanize: true, // enable realistic mouse movement to reduce bot detection\r\n153|            // fonts: ['Times New Roman'] // <- custom Camoufox options\r\n154|        }),\r\n155|    },\r\n156|});\r\n157|\r\n158|await crawler.run(startUrls);\r\n159|\r\n160|// Exit successfully\r\n161|await Actor.exit();\r\n162|",
