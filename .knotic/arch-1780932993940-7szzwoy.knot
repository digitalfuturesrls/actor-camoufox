      "agent": "main",
      "content": "File: src/routes.ts (161 lines) [hash:12ba6846]\n1|import { createPlaywrightRouter } from '@crawlee/playwright';\r\n2|\r\n3|export const router = createPlaywrightRouter();\r\n4|\r\n5|router.addDefaultHandler(async ({ request, page, log, pushData }) => {\r\n6|    const warmupUrl = request.url;\r\n7|    const targetUrl = request.userData?.targetUrl as string | undefined;\r\n8|\r\n9|    log.info(`Warmup on first URL: ${warmupUrl}`);\r\n10|\r\n11|    // Warmup: scroll naturale e comportamento umano sulla pagina corrente\r\n12|    await page.evaluate(async () => {\r\n13|        const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\r\n14|        const totalHeight = document.body.scrollHeight;\r\n15|        const step = totalHeight / 8;\r\n16|\r\n17|        // Scendi lentamente\r\n18|        for (let i = 1; i <= 8; i++) {\r\n19|            window.scrollTo({ top: i * step, behavior: 'smooth' });\r\n20|            await delay(400 + Math.random() * 600);\r\n21|        }\r\n22|\r\n23|        // Pausa di lettura\r\n24|        await delay(1000 + Math.random() * 2000);\r\n25|\r\n26|        // Risali\r\n27|        for (let i = 7; i >= 0; i--) {\r\n28|            window.scrollTo({ top: i * step, behavior: 'smooth' });\r\n29|            await delay(300 + Math.random() * 400);\r\n30|        }\r\n31|    });\r\n32|\r\n33|    log.info('Warmup completed');\r\n34|\r\n35|\r\n36|    const bodyHTMLWU = await page.evaluate(() => document.body.innerHTML);\r\n37|    console.log('\\u{1F4C4} Body HTML (full) for warmupUrl:\\n', bodyHTMLWU);\r\n38|\r\n39|    // Se non c'e una seconda URL, termina qui\r\n40|    if (!targetUrl) {\r\n41|        log.info('No targetUrl provided, warmup only');\r\n42|        await pushData({\r\n43|            sourceUrl: warmupUrl,\r\n44|            timestamp: new Date().toISOString(),\r\n45|        });\r\n46|        return;\r\n47|    }\r\n48|\r\n49|    // Naviga alla seconda pagina con goto\r\n50|    log.info(`Navigating to target URL: ${targetUrl}`);\r\n51|    await page.goto(targetUrl, { waitUntil: 'domcontentloaded' });\r\n52|\r\n53|    // Attesa casuale per simulare lettura pagina\r\n54|    await page.waitForTimeout(1500 + Math.random() * 2500);\r\n55|\r\n56|    // Progressive multi-step scroll to trigger lazy-loaded content\r\n57|    const scrollStep = 600;\r\n58|    const maxScrolls = 20;\r\n59|    let scrollCount = 0;\r\n60|    let lastHeight = await page.evaluate(() => document.body.scrollHeight);\r\n61|    let stalledCount = 0;\r\n62|    let finalScrollY = 0;\r\n63|\r\n64|    try {\r\n65|        for (let i = 0; i < maxScrolls; i++) {\r\n66|            await page.evaluate(\r\n67|                (step) => window.scrollBy(0, step),\r\n68|                scrollStep,\r\n69|            );\r\n70|            await page.waitForTimeout(500);\r\n71|\r\n72|            const { scrollY, scrollHeight, innerHeight } = await page.evaluate(() => ({\r\n73|                scrollY: window.scrollY,\r\n74|                scrollHeight: document.body.scrollHeight,\r\n75|                innerHeight: window.innerHeight,\r\n76|            }));\r\n77|\r\n78|            finalScrollY = scrollY;\r\n79|            scrollCount++;\r\n80|\r\n81|            // Break if bottom reached\r\n82|            if (scrollY + innerHeight >= scrollHeight) {\r\n83|                log.info(`Scroll ${scrollCount}: bottom reached at scrollY=${scrollY}`);\r\n84|                break;\r\n85|            }\r\n86|\r\n87|            // Break if content height hasn't increased for 3 consecutive scrolls\r\n88|            if (scrollHeight === lastHeight) {\r\n89|                stalledCount++;\r\n90|                if (stalledCount >= 3) {\r\n91|                    log.info(`Scroll ${scrollCount}: content stalled, breaking`);\r\n92|                    break;\r\n93|                }\r\n94|            } else {\r\n95|                stalledCount = 0;\r\n96|                lastHeight = scrollHeight;\r\n97|            }\r\n98|        }\r\n99|\r\n100|        log.info(`Scroll complete: ${scrollCount} scrolls, final scrollY=${finalScrollY}`);\r\n101|    } catch (err) {\r\n102|        log.warning(`Progressive scroll failed, falling back to single scroll: ${err}`);\r\n103|        try {\r\n104|            const fallback = await page.evaluate(() => document.body.scrollHeight);\r\n105|            const fallbackScroll = Math.min(fallback * 0.3, 800);\r\n106|            await page.evaluate((y) => window.scrollTo(0, y), fallbackScroll);\r\n107|            await page.waitForTimeout(1000);\r\n108|        } catch {\r\n109|            // ignore\r\n110|        }\r\n111|    }\r\n112|\r\n113|    // ─── DEBUG: page state (for targetUrl) ─────────────────\r\n114|    console.log('\\u{1F50D} Page URL:', targetUrl);\r\n115|    console.log('\\u{1F4D0} Scroll position:', await page.evaluate(() => window.scrollY));\r\n116|    console.log('\\u{1F4CF} Page height:', await page.evaluate(() => document.body.scrollHeight));\r\n117|\r\n118|    // ─── DEBUG: page body HTML (targetUrl) ───────────────\r\n119|    const bodyHTML = await page.evaluate(() => document.body.innerHTML);\r\n120|    console.log('\\u{1F4C4} Body HTML (full) for targetUrl:\\n', bodyHTML);\r\n121|\r\n122|    // Screenshot for visual inspection\r\n123|    try {\r\n124|        await page.screenshot({ path: 'screenshots/debug-fullpage.png', fullPage: true });\r\n125|        console.log('\\u{1F4F7} Screenshot saved: screenshots/debug-fullpage.png');\r\n126|    } catch (err) {\r\n127|        console.warn('\\u{26A0} Screenshot failed:', err);\r\n128|    }\r\n129|\r\n130|    // ─── DEBUG: link extraction ──────────────────────────\r\n131|    log.info('Extracting announcements with xpath...');\r\n132|    const annunciLinks = await page.locator('xpath=//a[contains(@href, \"annunci\")]').evaluateAll(\r\n133|        (els) =>\r\n134|            els.map((el) => ({\r\n135|                href: el.getAttribute('href') ?? '',\r\n136|                text: el.textContent?.trim() ?? '',\r\n137|            })),\r\n138|    );\r\n139|\r\n140|    const annunciCount = annunciLinks.length;\r\n141|    console.log(`\\u{1F50D} Annunci links found (href contains 'annunci'): ${annunciCount}`);\r\n142|    if (annunciCount > 0) {\r\n143|        console.log(`\\u{1F4A1} First ${Math.min(10, annunciCount)} annunci links:`);\r\n144|        annunciLinks.slice(0, 10).forEach((l, i) =>\r\n145|            console.log(`  [${i + 1}] href=${l.href}  text=${l.text?.substring(0, 80).replace(/\\s+/g, ' ')}`), // eslint-disable-line no-console\r\n146|        );\r\n147|    }\r\n148|\r\n149|    // Use hrefs (correct extraction) for dataset push\r\n150|    const hrefs = annunciLinks.map((l) => l.href);\r\n151|\r\n152|    log.info(`Found ${hrefs.length} links with href containing \"annunci\"`);\r\n153|\r\n154|    await pushData({\r\n155|        warmupUrl,\r\n156|        targetUrl,\r\n157|        announcementLinks: hrefs,\r\n158|        extractedAt: new Date().toISOString(),\r\n159|    });\r\n160|});\r\n161|",
