t Actor.init();\r\n53|\r\n54|// Structure of input is defined in input_schema.json\r\n55|const { startUrls = [{ url: 'https://apify.com' }], maxRequestsPerCrawl = 100 } =\r\n56|    (await Actor.getInput<Input>()) ?? ({} as Input);\r\n57|\r\n58|// `checkAccess` flag ensures the proxy credentials are valid, but the check can take a few hundred milliseconds.\r\n59|// Disable it for short runs if you are sure your proxy configuration is correct\r\n60|const proxyConfiguration = await Actor.createProxyConfiguration({\r\n61|    groups: ['RESIDENTIAL'],\r\n62|    countryCode: 'IT',\r\n63|    checkAccess: true\r\n64|});\r\n65|\r\n66|// Randomize viewport and use virtual headless mode for enhanced stealth\r\n67|const viewport = getRandomViewport();\r\n68|const useVirtualDisplay = process.env.HEADLESS_VIRTUAL !== 'false';\r\n69|console.log(`Using viewport ${viewport[0]}×${viewport[1]} and headless mode: ${useVirtualDisplay ? 'virtual' : 'standard'}`);\r\n70|\r\n71|const crawler = new PlaywrightCrawler({\r\n72|    maxRequestsPerCrawl,\r\n73|    useSessionPool: true,\r\n74|    sessionPoolOptions: { maxPoolSize: 5 },\r\n75|    maxConcurrency: 1,\r\n76|    maxRequestRetries: 3,\r\n77|    requestHandler: router,\r\n78|    preNavigationHooks: [\r\n79|        // Human-like behavior: random delay before navigation\r\n80|        async ({ page }, _context) => {\r\n81|            try {\r\n82|                // Random delay 1-4 seconds to simulate human hesitation\r\n83|                await page.waitForTimeout(1000 + Math.random() * 3000);\r\n84|            } catch (err) {\r\n85|                log.warning('Pre-navigation delay interrupted', { error: String(err) });\r\n86|            }\r\n87|\r\n88|            // Simulate cookie consent acceptance\r\n89|            try {\r\n90|                await page.evaluate(() => {\r\n91|                    document.cookie = 'cookie_consent=true; path=/; max-age=3600';\r\n92|                });\r\n93|            } catch (err) {\r\n94|                log.warning('Cookie consent simulation failed', { error: String(err) });\r\n95|            }\r\n96|        },\r\n97|        // Block trackers and analytics domains\r\n98|        async ({ page }) => {\r\n99|            await page.route('**/*', async (route) => {\r\n100|                const url = route.request().url();\r\n101|                const shouldBlock = BLOCKED_PATTERNS.some((pattern) => pattern.test(url));\r\n102|                if (shouldBlock) {\r\n103|                    await route.abort('blockedbyclient');\r\n104|                } else {\r\n105|                    await route.continue();\r\n106|                }\r\n107|            });\r\n108|        },\r\n109|    ],\r\n110|    postNavigationHooks: [\r\n111|        // Human-like behavior: simulate reading after page load\r\n112|        async ({ page }) => {\r\n113|            try {\r\n114|                // Progressive scroll: 10 steps with 300ms intervals\r\n115|                await page.evaluate(async () => {\r\n116|                    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\r\n117|                    const totalHeight = document.body.scrollHeight;\r\n118|                    const step = totalHeight / 10;\r\n119|                    for (let i = 1; i <= 10; i++) {\r\n120|                        window.scrollTo(0, i * step);\r\n121|                        await delay(300);\r\n122|                    }\r\n123|                });\r\n124|\r\n125|                // Mouse emulation: move mouse to random positions\r\n126|                const viewport = page.viewportSize() || { width: 1280, height: 720 };\r\n127|                for (let i = 0; i < 3; i++) {\r\n128|                    await page.mouse.move(\r\n129|                        Math.random() * viewport.width,\r\n130|                        Math.random() * viewport.height\r\n131|                    );\r\n132|                    await page.waitForTimeout(500);\r\n133|                }\r\n134|\r\n135|                // Reading wait: simulate reading time (2-5 seconds)\r\n136|                await page.waitForTimeout(2000 + Math.random() * 3000);\r\n137|            } catch (err) {\r\n138|                log.warning('Post-navigation hooks interrupted', { error: String(err) });\r\n139|            }\r\n140|        },\r\n141|    ],\r\n142|\r\n143|    launchContext: {\r\n144|        launcher: firefox,\r\n145|        launchOptions: await camoufoxLaunchOptions({\r\n146|            headless: true,\r\n147|            window: viewport,\r\n148|            proxy: await proxyConfiguration?.newUrl(),\r\n149|            geoip: true,\r\n150|            locale: \"it-IT\",\r\n151|            env: { TZ: 'Europe/Rome' },\r\n152|            humanize: true, // enable realistic mouse movement to reduce bot detection\r\n153|            // fonts: ['Times New Roman'] // <- custom Camoufox options\r\n154|        }),\r\n155|    },\r\n156|});\r\n157|\r\n158|// Map input to requests with labels from tags\r\n159|log.info('Mapping input to requests with labels...', { count: startUrls.length });\r\n160|\r\n161|const requests = startUrls.map((item) => {\r\n162|    const label = item.tag && item.tag.trim() ? item.tag.trim() : undefined;\r\n163|\r\n164|    if (!item.url) {\r\n165|        log.warning('Missing url in startUrl entry', { item });\r\n166|    }\r\n167|\r\n168|    return {\r\n169|        url: item.url,\r\n170|        label,\r\n171|    };\r\n172|});\r\n173|\r\n174|await crawler.run(requests);\r\n175|\r\n176|// Exit successfully\r\n177|await Actor.exit();\r\n178|",
