      "content": "File: src/routes.ts (120 lines) [hash:c65d4dc0]\n1|import { createPlaywrightRouter } from '@crawlee/playwright';\n2|\n3|export const router = createPlaywrightRouter();\n4|\n5|router.addDefaultHandler(async ({ request, page, log, pushData }) => {\n6|    const warmupUrl = request.url;\n7|    const targetUrl = request.userData?.targetUrl as string | undefined;\n8|\n9|    log.info(`Warmup on first URL: ${warmupUrl}`);\n10|\n11|    // Warmup: scroll naturale e comportamento umano sulla pagina corrente\n12|    await page.evaluate(async () => {\n13|        const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\n14|        const totalHeight = document.body.scrollHeight;\n15|        const step = totalHeight / 8;\n16|\n17|        // Scendi lentamente\n18|        for (let i = 1; i <= 8; i++) {\n19|            window.scrollTo({ top: i * step, behavior: 'smooth' });\n20|            await delay(400 + Math.random() * 600);\n21|        }\n22|\n23|        // Pausa di lettura\n24|        await delay(1000 + Math.random() * 2000);\n25|\n26|        // Risali\n27|        for (let i = 7; i >= 0; i--) {\n28|            window.scrollTo({ top: i * step, behavior: 'smooth' });\n29|            await delay(300 + Math.random() * 400);\n30|        }\n31|    });\n32|\n33|    log.info('Warmup completed');\n34|\n35|    // Se non c'e una seconda URL, termina qui\n36|    if (!targetUrl) {\n37|        log.info('No targetUrl provided, warmup only');\n38|        await pushData({\n39|            sourceUrl: warmupUrl,\n40|            timestamp: new Date().toISOString(),\n41|        });\n42|        return;\n43|    }\n44|\n45|    // Naviga alla seconda pagina con goto\n46|    log.info(`Navigating to target URL: ${targetUrl}`);\n47|    await page.goto(targetUrl, { waitUntil: 'domcontentloaded' });\n48|\n49|    // Attesa casuale per simulare lettura pagina\n50|    await page.waitForTimeout(1500 + Math.random() * 2500);\n51|\n52|    // Scroll casuale sulla pagina target\n53|    await page.evaluate(async () => {\n54|        const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\n55|        const totalHeight = document.body.scrollHeight;\n56|        const scrollTo = Math.min(totalHeight * 0.3, 800);\n57|        window.scrollTo({ top: scrollTo, behavior: 'smooth' });\n58|        await delay(500 + Math.random() * 1000);\n59|    });\n60|\n61|    // ─── DEBUG: page state ───────────────────────────────\n62|    console.log('\\u{1F50D} Page URL:', request.url);\n63|    console.log('\\u{1F4D0} Scroll position:', await page.evaluate(() => window.scrollY));\n64|    console.log('\\u{1F4CF} Page height:', await page.evaluate(() => document.body.scrollHeight));\n65|\n66|    // Screenshot for visual inspection\n67|    try {\n68|        await page.screenshot({ path: 'screenshots/debug-fullpage.png', fullPage: true });\n69|        console.log('\\u{1F4F7} Screenshot saved: screenshots/debug-fullpage.png');\n70|    } catch (err) {\n71|        console.warn('\\u{26A0} Screenshot failed:', err);\n72|    }\n73|\n74|    // ─── DEBUG: link extraction ──────────────────────────\n75|    log.info('Extracting announcements with xpath...');\n76|    const allLinks = await page.locator('xpath=//a[@href]').evaluateAll(\n77|        (els) =>\n78|            els.map((el) => ({\n79|                href: el.getAttribute('href'),\n80|                text: el.textContent?.trim() ?? '',\n81|            })),\n82|    );\n83|\n84|    const totalAnchors = allLinks.length;\n85|\n86|    const annunciLinks = allLinks.filter(\n87|        (l) =>\n88|            (l.href && l.href.toLowerCase().includes('annunci')) ||\n89|            (l.text && l.text.toLowerCase().includes('annunci')),\n90|    );\n91|\n92|    const annunciCount = annunciLinks.length;\n93|    console.log(`\\u{1F50D} Total <a> elements: ${totalAnchors}`);\n94|    console.log(`\\u{1F50D} Annunci-like links (href or text contains 'annunci'): ${annunciCount}`);\n95|    if (annunciCount > 0) {\n96|        console.log(`\\u{1F4A1} First ${Math.min(10, annunciCount)} annunci links:`);\n97|        annunciLinks.slice(0, 10).forEach((l, i) =>\n98|            console.log(`  [${i + 1}] href=${l.href}  text=${l.text?.substring(0, 80)}`), // eslint-disable-line no-console\n99|        );\n100|    } else {\n101|        // Dump the first 30 hrefs so we can see what was actually extracted\n102|        console.warn('\\u{26A0} No annunci links found — dumping first 30 hrefs for inspection:');\n103|        allLinks.slice(0, 30).forEach((l, i) =>\n104|            console.log(`  [${i + 1}] href=${l.href}  text=${l.text?.substring(0, 80)}`), // eslint-disable-line no-console\n105|        );\n106|    }\n107|\n108|    // Use hrefs (correct extraction) for dataset push\n109|    const hrefs = annunciLinks.map((l) => l.href ?? '');\n110|\n111|    log.info(`Found ${hrefs.length} links containing \"annunci\"`); // this log is now accurate\n112|\n113|    await pushData({\n114|        warmupUrl,\n115|        targetUrl,\n116|        announcementLinks: hrefs,\n117|        extractedAt: new Date().toISOString(),\n118|    });\n119|});\n120|",
