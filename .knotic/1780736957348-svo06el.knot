pm\r\n49|\r\n50|# Copy built JS files from builder image\r\n51|COPY --from=builder --chown=myuser:myuser /home/myuser/dist ./dist\r\n52|\r\n53|# Next, copy the remaining files and directories with the source code.\r\n54|# Since we do this after NPM install, quick build will be really fast\r\n55|# for most source file changes.\r\n56|COPY --chown=myuser:myuser . ./\r\n57|\r\n58|# Ensure Camoufox browser is downloaded for the runtime user.\r\n59|# The postinstall runs as root during npm install, which places the binary\r\n60|# in /root/.cache/ instead of /home/myuser/.cache/ where the runtime expects it.\r\n61|USER myuser\r\n62|RUN npx camoufox-js fetch\r\n63|\r\n64|# Run the image.\r\n65|CMD [\"node\", \"dist/main.js\"]\r\n66|",
