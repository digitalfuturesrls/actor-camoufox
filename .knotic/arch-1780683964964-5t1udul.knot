or.getInput<Input>()) ?? ({} as Input);\r\n48|\r\n49|// `checkAccess` flag ensures the proxy credentials are valid, but the check can take a few hundred milliseconds.\r\n50|// Disable it for short runs if you are sure your proxy configuration is correct\r\n51|const proxyConfiguration = await Actor.createProxyConfiguration({\r\n52|    groups: ['RESIDENTIAL'],\r\n53|    countryCode: 'IT',\r\n54|    checkAccess: true\r\n55|});\r\n56|\r\n57|// Randomize viewport and use virtual headless mode for enhanced stealth\r\n58|const viewport = getRandomViewport();\r\n59|const useVirtualDisplay = process.env.HEADLESS_VIRTUAL !== 'false';\r\n60|console.log(`Using viewport ${viewport[0]}×${viewport[1]} and headless mode: ${useVirtualDisplay ? 'virtual' : 'standard'}`);\r\n61|\r\n62|const crawler = new PlaywrightCrawler({\r\n63|    proxyConfiguration,\r\n64|    maxRequestsPerCrawl,\r\n65|    requestHandler: router,\r\n66|    launchContext: {\r\n67|        launcher: firefox,\r\n68|        launchOptions: await camoufoxLaunchOptions({\r\n69|            headless: true, // Camoufox handles virtual display internally when geoip is enabled\r\n70|            window: viewport,\r\n71|            proxy: await proxyConfiguration?.newUrl(),\r\n72|            geoip: true,\r\n73|            // fonts: ['Times New Roman'] // <- custom Camoufox options\r\n74|        }),\r\n75|    },\r\n76|});\r\n77|\r\n78|await crawler.run(startUrls);\r\n79|\r\n80|// Exit successfully\r\n81|await Actor.exit();\r\n82|",
