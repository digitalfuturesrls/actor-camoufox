ONNECT' | 'PATCH';\r\n50|        headers?: Record<string, string>;\r\n51|        userData: Record<string, unknown>;\r\n52|    }[];\r\n53|    maxRequestsPerCrawl: number;\r\n54|}\r\n55|\r\n56|// Initialize the Apify SDK\r\n57|await Actor.init();\r\n58|\r\n59|// Structure of input is defined in input_schema.json\r\n60|const { startUrls = ['https://apify.com'], maxRequestsPerCrawl = 100 } =\r\n61|    (await Actor.getInput<Input>()) ?? ({} as Input);\r\n62|\r\n63|// `checkAccess` flag ensures the proxy credentials are valid, but the check can take a few hundred milliseconds.\r\n64|// Disable it for short runs if you are sure your proxy configuration is correct\r\n65|const proxyConfiguration = await Actor.createProxyConfiguration({\r\n66|    groups: ['RESIDENTIAL'],\r\n67|    countryCode: 'IT',\r\n68|    checkAccess: true\r\n69|});\r\n70|\r\n71|// Randomize viewport and use virtual headless mode for enhanced stealth\r\n72|const viewport = getRandomViewport();\r\n73|const useVirtualDisplay = process.env.HEADLESS_VIRTUAL !== 'false';\r\n74|console.log(`Using viewport ${viewport[0]}×${viewport[1]} and headless mode: ${useVirtualDisplay ? 'virtual' : 'standard'}`);\r\n75|\r\n76|const crawler = new PlaywrightCrawler({\r\n77|    maxRequestsPerCrawl,\r\n78|    useSessionPool: true,\r\n79|    sessionPoolOptions: { maxPoolSize: 5 },\r\n80|    maxConcurrency: 1,\r\n81|    maxRequestRetries: 3,\r\n82|    requestHandler: router,\r\n83|    preNavigationHooks: [\r\n84|        // Human-like behavior: random delay before navigation\r\n85|        async ({ page }, _context) => {\r\n86|            try {\r\n87|                // Random delay 1-4 seconds to simulate human hesitation\r\n88|                await page.waitForTimeout(1000 + Math.random() * 3000);\r\n89|            } catch (err) {\r\n90|                log.warning('Pre-navigation delay interrupted', { error: String(err) });\r\n91|            }\r\n92|\r\n93|            // Simulate cookie consent acceptance\r\n94|            try {\r\n95|                await page.evaluate(() => {\r\n96|                    document.cookie = 'cookie_consent=true; path=/; max-age=3600';\r\n97|                });\r\n98|            } catch (err) {\r\n99|                log.warning('Cookie consent simulation failed', { error: String(err) });\r\n100|            }\r\n101|        },\r\n102|        // Block trackers and analytics domains\r\n103|        async ({ page }) => {\r\n104|            await page.route('**/*', async (route) => {\r\n105|                const url = route.request().url();\r\n106|                const shouldBlock = BLOCKED_PATTERNS.some((pattern) => pattern.test(url));\r\n107|                if (shouldBlock) {\r\n108|                    await route.abort('blockedbyclient');\r\n109|                } else {\r\n110|                    await route.continue();\r\n111|                }\r\n112|            });\r\n113|        },\r\n114|    ],\r\n115|    postNavigationHooks: [\r\n116|        // Human-like behavior: simulate reading after page load\r\n117|        async ({ page }) => {\r\n118|            try {\r\n119|                // Progressive scroll: 10 steps with 300ms intervals\r\n120|                await page.evaluate(async () => {\r\n121|                    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\r\n122|                    const totalHeight = document.body.scrollHeight;\r\n123|                    const step = totalHeight / 10;\r\n124|                    for (let i = 1; i <= 10; i++) {\r\n125|                        window.scrollTo(0, i * step);\r\n126|                        await delay(300);\r\n127|                    }\r\n128|                });\r\n129|\r\n130|                // Mouse emulation: move mouse to random positions\r\n131|                const viewport = page.viewportSize() || { width: 1280, height: 720 };\r\n132|                for (let i = 0; i < 3; i++) {\r\n133|                    await page.mouse.move(\r\n134|                        Math.random() * viewport.width,\r\n135|                        Math.random() * viewport.height\r\n136|                    );\r\n137|                    await page.waitForTimeout(500);\r\n138|                }\r\n139|\r\n140|                // Reading wait: simulate reading time (2-5 seconds)\r\n141|                await page.waitForTimeout(2000 + Math.random() * 3000);\r\n142|            } catch (err) {\r\n143|                log.warning('Post-navigation hooks interrupted', { error: String(err) });\r\n144|            }\r\n145|        },\r\n146|    ],\r\n147|\r\n148|    launchContext: {\r\n149|        launcher: firefox,\r\n150|        launchOptions: await camoufoxLaunchOptions({\r\n151|            headless: true,\r\n152|            window: viewport,\r\n153|            proxy: await proxyConfiguration?.newUrl(),\r\n154|            geoip: true,\r\n155|            locale: \"it-IT\",\r\n156|            env: { TZ: 'Europe/Rome' },\r\n157|            humanize: true, // enable realistic mouse movement to reduce bot detection\r\n158|            // fonts: ['Times New Roman'] // <- custom Camoufox options\r\n159|        }),\r\n160|    },\r\n161|});\r\n162|\r\n163|await crawler.run(startUrls);\r\n164|\r\n165|// Exit successfully\r\n166|await Actor.exit();\r\n167|\n\n---\n\n[1] file.read: ERROR - File not found: file:///c%3A/Users/digit/Progetti/actor_new/src/stealth.ts. Verify path and check search(action:\"find\") for the correct name.\n\n---\n\n[2] file.read: File: src/routes.ts (22 lines) [hash:f18cfd21]\n1|import { createPlaywrightRouter } from '@crawlee/playwright';\r\n2|\r\n3|export const router = createPlaywrightRouter();\r\n4|\r\n5|router.addDefaultHandler(async ({ enqueueLinks, log }) => {\r\n6|    log.info(`enqueueing new URLs`);\r\n7|    await enqueueLinks({\r\n8|        globs: ['https://apify.com/*'],\r\n9|        label: 'detail',\r\n10|    });\r\n11|});\r\n12|\r\n13|router.addHandler('detail', async ({ request, page, log, pushData }) => {\r\n14|    const title = await page.title();\r\n15