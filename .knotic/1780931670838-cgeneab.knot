      "content": "File: src/main.ts (lines 1-50 of 195) [hash:a8cf58bf]\n1|/**\r\n2| * This template is a production ready boilerplate for developing with `PlaywrightCrawler`.\r\n3| * Use this to bootstrap your projects using the most up-to-date code.\r\n4| * If you're looking for examples or want to learn more, see README.\r\n5| */\r\n6|\r\n7|// For more information, see https://crawlee.dev\r\n8|import { PlaywrightCrawler } from '@crawlee/playwright';\r\n9|// For more information, see https://docs.apify.com/sdk/js\r\n10|import { Actor, log } from 'apify';\r\n11|import { launchOptions as camoufoxLaunchOptions } from 'camoufox-js';\r\n12|import { firefox } from 'playwright';\r\n13|\r\n14|// this is ESM project, and as such, it requires you to specify extensions in your relative imports\r\n15|// read more about this here: https://nodejs.org/docs/latest-v18.x/api/esm.html#mandatory-file-extensions\r\n16|// note that we need to use `.js` even when inside TS files\r\n17|import { router } from './routes.js';\r\n18|\r\n19|// Common desktop viewport sizes for fingerprint randomization\r\n20|const COMMON_VIEWPORTS: [number, number][] = [\r\n21|    [1920, 1080],\r\n22|    [1366, 768],\r\n23|    [1440, 900],\r\n24|    [1536, 864],\r\n25|    [1280, 720],\r\n26|];\r\n27|\r\n28|function getRandomViewport(): [number, number] {\r\n29|    return COMMON_VIEWPORTS[Math.floor(Math.random() * COMMON_VIEWPORTS.length)];\r\n30|}\r\n31|\r\n32|// Tracker and analytics domains to block\r\n33|const BLOCKED_PATTERNS = [\r\n34|    /doubleclick\\.net/,\r\n35|    /google-analytics\\.com/,\r\n36|    /googletagmanager\\.com/,\r\n37|    /facebook\\.net/,\r\n38|    /amazon-adsystem\\.com/,\r\n39|    /scorecardresearch\\.com/,\r\n40|    /hotjar\\.com/,\r\n41|    /mouseflow\\.com/,\r\n42|    /newrelic\\.com/,\r\n43|    /datadome\\.co/,\r\n44|    /adnxs\\.com/,\r\n45|    /accounts\\.google\\.com\\/gsi/,\r\n46|];\r\n47|\r\n48|\r\n49|interface Input {\r\n50|    startUrls: Array<{ url: string; tag?: string