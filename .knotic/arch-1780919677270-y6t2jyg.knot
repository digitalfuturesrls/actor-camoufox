g(`\\u{1F4A1} First ${Math.min(10, annunciCount)} annunci links:`);\n97|        annunciLinks.slice(0, 10).forEach((l, i) =>\n98|            console.log(`  [${i + 1}] href=${l.href}  text=${l.text?.substring(0, 80)}`), // eslint-disable-line no-console\n99|        );\n100|    } else {\n101|        // Dump the first 30 hrefs so we can see what was actually extracted\n102|        console.warn('\\u{26A0} No annunci links found — dumping first 30 hrefs for inspection:');\n103|        allLinks.slice(0, 30).forEach((l, i) =>\n104|            console.log(`  [${i + 1}] href=${l.href}  text=${l.text?.substring(0, 80)}`), // eslint-disable-line no-console\n105|        );\n106|    }\n107|\n108|    // Use hrefs (correct extraction) for dataset push\n109|    const hrefs = annunciLinks.map((l) => l.href ?? '');\n110|\n111|    log.info(`Found ${hrefs.length} links containing \"annunci\"`); // this log is now accurate\n112|\n113|    await pushData({\n114|        warmupUrl,\n115|        targetUrl,\n116|        announcementLinks: hrefs,\n117|        extractedAt: new Date().toISOString(),\n118|    });\n119|});\n120|",
