      "content": "File: src/routes.ts (153 lines) [hash:97175bf5]\n1|import { createPlaywrightRouter } from '@crawlee/playwright';\n2|\n3|export const router = createPlaywrightRouter();\n4|\n5|router.addDefaultHandler(async ({ request, page, log, pushData }) => {\n6|    const warmupUrl = request.url;\n7|    const targetUrl = request.userData?.targetUrl as string | undefined;\n8|\n9|    log.info(`Warmup on first URL: ${warmupUrl}`);\n10|\n11|    // Warmup: scroll naturale e comportamento umano sulla pagina corrente\n12|    await page.evaluate(async () => {\n13|        const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\n14|        const totalHeight = document.body.scrollHeight;\n15|        const step = totalHeight / 8;\n16|\n17|        // Scendi lentamente\n18|        for (let i = 1; i <= 8; i++) {\n19|            window.scrollTo({ top: i * step, behavior: 'smooth' });\n20|            await delay(400 + Math.random() * 600);\n21|        }\n22|\n23|        // Pausa di lettura\n24|        await delay(1000 + Math.random() * 2000);\n25|\n26|        // Risali\n27|        for (let i = 7; i >= 0; i--) {\n28|            window.scrollTo({ top: i * step, behavior: 'smooth' });\n29|            await delay(300 + Math.random() * 400);\n30|        }\n31|    });\n32|\n33|    log.info('Warmup completed');\n34|\n35|    // Se non c'e una seconda URL, termina qui\n36|    if (!targetUrl) {\n37|        log.info('No targetUrl provided, warmup only');\n38|        await pushData({\n39|            sourceUrl: warmupUrl,\n40|            timestamp: new Date().toISOString(),\n41|        });\n42|        return;\n43|    }\n44|\n45|    // Naviga alla seconda pagina con goto\n46|    log.info(`Navigating to target URL: ${targetUrl}`);\n47|    await page.goto(targetUrl, { waitUntil: 'domcontentloaded' });\n48|\n49|    // Attesa casuale per simulare lettura pagina\n50|    await page.waitForTimeout(1500 + Math.random() * 2500);\n51|\n52|    // Progressive multi-step scroll to trigger lazy-loaded content\n53|    const scrollStep = 600;\n54|    const maxScrolls = 20;\n55|    let scrollCount = 0;\n56|    let lastHeight = await page.evaluate(() => document.body.scrollHeight);\n57|    let stalledCount = 0;\n58|    let finalScrollY = 0;\n59|\n60|    try {\n61|        for (let i = 0; i < maxScrolls; i++) {\n62|            await page.evaluate(\n63|                (step) => window.scrollBy(0, step),\n64|                scrollStep,\n65|            );\n66|            await page.waitForTimeout(500);\n67|\n68|            const { scrollY, scrollHeight, innerHeight } = await page.evaluate(() => ({\n69|                scrollY: window.scrollY,\n70|                scrollHeight: document.body.scrollHeight,\n71|                innerHeight: window.innerHeight,\n72|            }));\n73|\n74|            finalScrollY = scrollY;\n75|            scrollCount++;\n76|\n77|            // Break if bottom reached\n78|            if (scrollY + innerHeight >= scrollHeight) {\n79|                log.info(`Scroll ${scrollCount}: bottom reached at scrollY=${scrollY}`);\n80|                break;\n81|            }\n82|\n83|            // Break if content height hasn't increased for 3 consecutive scrolls\n84|            if (scrollHeight === lastHeight) {\n85|                stalledCount++;\n86|                if (stalledCount >= 3) {\n87|                    log.info(`Scroll ${scrollCount}: content stalled, breaking`);\n88|                    break;\n89|                }\n90|            } else {\n91|                stalledCount = 0;\n92|                lastHeight = scrollHeight;\n93|            }\n94|        }\n95|\n96|        log.info(`Scroll complete: ${scrollCount} scrolls, final scrollY=${finalScrollY}`);\n97|    } catch (err) {\n98|        log.warning(`Progressive scroll failed, falling back to single scroll: ${err}`);\n99|        try {\n100|            const fallback = await page.evaluate(() => document.body.scrollHeight);\n101|            const fallbackScroll = Math.min(fallback * 0.3, 800);\n102|            await page.evaluate((y) => window.scrollTo(0, y), fallbackScroll);\n103|            await page.waitForTimeout(1000);\n104|        } catch {\n105|            // ignore\n106|        }\n107|    }\n108|\n109|    // ─── DEBUG: page state ───────────────────────────────\n110|    console.log('\\u{1F50D} Page URL:', request.url);\n111|    console.log('\\u{1F4D0} Scroll position:', await page.evaluate(() => window.scrollY));\n112|    console.log('\\u{1F4CF} Page height:', await page.evaluate(() => document.body.scrollHeight));\n113|\n114|    // Screenshot for visual inspection\n115|    try {\n116|        await page.screenshot({ path: 'screenshots/debug-fullpage.png', fullPage: true });\n117|        console.log('\\u{1F4F7} Screenshot saved: screenshots/debug-fullpage.png');\n118|    } catch (err) {\n119|        console.warn('\\u{26A0} Screenshot failed:', err);\n120|    }\n121|\n122|    // ─── DEBUG: link extraction ──────────────────────────\n123|    log.info('Extracting announcements with xpath...');\n124|    const annunciLinks = await page.locator('xpath=//a[contains(@href, \"annunci\")]').evaluateAll(\n125|        (els) =>\n126|            els.map((el) => ({\n127|                href: el.getAttribute('href') ?? '',\n128|                text: el.textContent?.trim() ?? '',\n129|            })),\n130|    );\n131|\n132|    const annunciCount = annunciLinks.length;\n133|    console.log(`\\u{1F50D} Annunci links found (href contains 'annunci'): ${annunciCount}`);\n134|    if (annunciCount > 0) {\n135|        console.log(`\\u{1F4A1} First ${Math.min(10, annunciCount)} annunci links:`);\n136|        annunciLinks.slice(0, 10).forEach((l, i) =>\n137|            console.log(`  [${i + 1}] href=${l.href}  text=${l.text?.substring(0, 80).replace(/\\s+/g, ' ')}`), // eslint-disable-line no-console\n138|        );\n139|    }\n140|\n141|    // Use hrefs (correct extraction) for dataset push\n142|    const hrefs = annunciLinks.map((l) => l.href);\n143|\n144|    log.info(`Found ${hrefs.length} links with href containing \"annunci\"`);\n145|\n146|    await pushData({\n147|        warmupUrl,\n148|        targetUrl,\n149|        announcementLinks: hrefs,\n150|        extractedAt: new Date().toISOString(),\n151|    });\n152|});\n153|",
