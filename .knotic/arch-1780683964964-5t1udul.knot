      "content": "File: src/main.ts (76 lines) [hash:278bc03b]\n1|/**\r\n2| * This template is a production ready boilerplate for developing with `PlaywrightCrawler`.\r\n3| * Use this to bootstrap your projects using the most up-to-date code.\r\n4| * If you're looking for examples or want to learn more, see README.\r\n5| */\r\n6|\r\n7|// For more information, see https://crawlee.dev\r\n8|import { PlaywrightCrawler } from '@crawlee/playwright';\r\n9|// For more information, see https://docs.apify.com/sdk/js\r\n10|import { Actor } from 'apify';\r\n11|import { launchOptions as camoufoxLaunchOptions } from 'camoufox-js';\r\n12|import { firefox } from 'playwright';\r\n13|\r\n14|// Common desktop viewport sizes for fingerprint randomization\r\n15|const COMMON_VIEWPORTS: [number, number][] = [\r\n16|    [1920, 1080],\r\n17|    [1366, 768],\r\n18|    [1440, 900],\r\n19|    [1536, 864],\r\n20|    [1280, 720],\r\n21|];\r\n22|\r\n23|function getRandomViewport(): [number, number] {\r\n24|    return COMMON_VIEWPORTS[Math.floor(Math.random() * COMMON_VIEWPORTS.length)];\r\n25|}\r\n26|\r\n27|// this is ESM project, and as such, it requires you to specify extensions in your relative imports\r\n28|// read more about this here: https://nodejs.org/docs/latest-v18.x/api/esm.html#mandatory-file-extensions\r\n29|// note that we need to use `.js` even when inside TS files\r\n30|import { router } from './routes.js';\r\n31|\r\n32|interface Input {\r\n33|    startUrls: {\r\n34|        url: string;\r\n35|        method?: 'GET' | 'HEAD' | 'POST' | 'PUT' | 'DELETE' | 'TRACE' | 'OPTIONS' | 'CONNECT' | 'PATCH';\r\n36|        headers?: Record<string, string>;\r\n37|        userData: Record<string, unknown>;\r\n38|    }[];\r\n39|    maxRequestsPerCrawl: number;\r\n40|}\r\n41|\r\n42|// Initialize the Apify SDK\r\n43|await Actor.init();\r\n44|\r\n45|// Structure of input is defined in input_schema.json\r\n46|const { startUrls = ['https://apify.com'], maxRequestsPerCrawl = 100 } =\r\n47|    (await Act