r] {\nsrc/main.ts:28: return COMMON_VIEWPORTS[Math.floor(Math.random() * COMMON_VIEWPORTS.length)];\nsrc/main.ts:65: // Randomize viewport and use virtual headless mode for enhanced stealth\nsrc/main.ts:66: const viewport = getRandomViewport();\nsrc/main.ts:78: // Human-like behavior: random delay before navigation\nsrc/main.ts:81: // Random delay 1-4 seconds to simulate human hesitation\nsrc/main.ts:82: await page.waitForTimeout(1000 + Math.random() * 3000);\nsrc/main.ts:84: log.warning('Pre-navigation delay interrupted', { error: String(err) });\nsrc/main.ts:113: // Progressive scroll: 10 steps with 300ms intervals\nsrc/main.ts:115: const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));\nsrc/main.ts:116: const totalHeight = document.body.scrollHeight;\nsrc/main.ts:119: window.scrollTo(0, i * step);\nsrc/main.ts:120: await delay(300);\nsrc/main.ts:124: // Mouse emulation: move mouse to random positions\nsrc/main.ts:127: await page.mouse.move(\nsrc/main.ts:128: Math.random() * viewport.width,\nsrc/main.ts:129: Math.random() * viewport.height\nsrc/main.ts:131: await page.waitForTimeout(500);\nsrc/main.ts:135: await page.waitForTimeout(2000 + Math.random() * 3000);\nsrc/main.ts:151: humanize: true, // enable realistic mouse movement to reduce bot detection",
